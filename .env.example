# Fonte de dados: gratuita | plataforma (login + pesquisa salva) | oficial (api-key)
FONTE=gratuita

# --- Plataforma (FONTE=plataforma) ---
PORTAL_EMAIL=
PORTAL_SENHA=
# UUID da pesquisa salva (campo pesquisaId na URL do portal)
PESQUISA_ID=
# Resultados por pagina na plataforma (max testado: 1000)
LIMITE_PAGINA_PLATAFORMA=1000

# Chave da API (opcional: preenchida automaticamente apos login na plataforma)
# Obtenha em: https://portal.casadosdados.com.br/plataforma/api/chave
API_KEY=

# Cookie cf_clearance do Cloudflare (apenas fonte gratuita)
CF_CLEARANCE=

# User-Agent do navegador
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Tempo de espera (segundos) entre requisicoes
DELAY_ENTRE_REQUISICOES=4.0

# Numero maximo de paginas da pesquisa (plataforma: 4043 registros / 1000 = 5 paginas)
MAX_PAGINAS=100

# Para apos encontrar N resultados (0 = ilimitado). Util para testes.
MAX_RESULTADOS=0

MAX_ERROS_CONSECUTIVOS=5
IMPERSONATE=chrome120
